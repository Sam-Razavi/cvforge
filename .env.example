PORT=3000
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cvforge

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Queue
MAX_CONCURRENCY=5
RATE_LIMIT_MAX=20
RATE_LIMIT_DURATION_MS=60000

# Bull Board
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-me

# CORS
CORS_ORIGINS=http://localhost:5173,https://applyluma.vercel.app
